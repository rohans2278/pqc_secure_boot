+    {
+      m[i] = sm[MLDSA_CRYPTO_BYTES + i];
+    }
+  }
+
+cleanup:
+
+  if (ret != 0)
+  {
+    /* To be on the safe-side, we zeroize the message buffer. */
+    *mlen = 0;
+    mld_memset(m, 0, smlen);
+  }
+
+  return ret;
